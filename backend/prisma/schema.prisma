generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Every message Evolution reports (incoming + outgoing, DMs + groups).
model Message {
  id          String      @id @default(cuid())
  waMessageId String      @unique
  chatId      String
  chatName    String?
  senderPhone String?
  senderName  String?
  content     String
  rawMessage  Json
  messageType MessageType
  isGroup     Boolean     @default(false)
  isFromMe    Boolean     @default(false)
  isSelfChat  Boolean     @default(false)
  timestamp   DateTime
  createdAt   DateTime    @default(now())

  commandLogs CommandLog[]

  @@index([chatId, timestamp])
  @@index([isSelfChat, isFromMe, timestamp])
  @@index([chatName])
  @@index([timestamp])
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  CONTACT
  LOCATION
  OTHER
}

// Reminders scheduled by /reminder command; fired by the scheduler service.
model Reminder {
  id           String         @id @default(cuid())
  scheduledAt  DateTime
  message      String
  status       ReminderStatus @default(PENDING)
  createdByCmd String?
  createdAt    DateTime       @default(now())
  sentAt       DateTime?
  error        String?

  @@index([status, scheduledAt])
}

enum ReminderStatus {
  PENDING
  SENT
  MISSED
  CANCELLED
  FAILED
}

// Audit log of every command execution.
model CommandLog {
  id         String        @id @default(cuid())
  command    String
  args       String?
  rawInput   String
  messageId  String?
  message    Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  output     String?
  status     CommandStatus
  error      String?
  executedAt DateTime      @default(now())
  durationMs Int?

  @@index([executedAt])
  @@index([command, executedAt])
}

enum CommandStatus {
  SUCCESS
  FAILURE
  NOT_FOUND
}

// Key/value store for runtime config (e.g., detected self JID).
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// The single WhatsApp instance this app manages.
model Instance {
  id              String         @id @default(cuid())
  name            String         @unique
  phoneNumber     String?
  ownerJid        String?
  status          InstanceStatus @default(DISCONNECTED)
  lastConnectedAt DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum InstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

// A person authorized to trigger commands by messaging the owner.
// When enabled, messages from this phone starting with "/" are processed
// as if the owner typed them — but the reply goes to the DELEGATE, not
// to self-chat.
model Delegate {
  id        String   @id @default(cuid())
  phone     String   @unique           // digits only, e.g. "14255245126"
  name      String                     // display name, e.g. "Jack Be Home Remodeling"
  enabled   Boolean  @default(true)    // owner can toggle on/off
  // Permissions: which command prefixes this delegate can use.
  // Empty array = read-only defaults (status*, audit, help, schedules, reminders).
  // ["*"] = all commands (same as owner). Use with caution.
  allowedCommands String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generic scheduled task — runs an Action on a cron schedule or one-shot.
// Designed to be extensible: actionType is a plain string keyed into the
// ActionRegistry at runtime, and actionPayload is free-form JSON.
model ScheduledTask {
  id              String              @id @default(cuid())
  name            String                                       // human name for /schedules listing
  enabled         Boolean             @default(true)

  // One of these two must be set:
  cronExpression  String?                                      // e.g. "0 9 * * 1" (Mon 9am)
  fireAt          DateTime?                                    // one-shot absolute time

  // Action to run when the task fires.
  actionType      String                                       // "sendText" | "runCommand" | "webhook" | "sendVoice"
  actionPayload   Json                                         // arbitrary payload per action type

  lastFiredAt     DateTime?
  nextFireAt      DateTime?
  lastError       String?
  lastResult      String?                                      // truncated last action output
  runCount        Int                 @default(0)
  failureCount    Int                 @default(0)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([enabled, nextFireAt])
  @@index([enabled, fireAt])
}
