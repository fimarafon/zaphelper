# ============================================================================
# zaphelper — .env.example
#
# Copy this file to .env and fill in the values before running docker compose.
#   cp .env.example .env
#
# How to generate secrets:
#   openssl rand -hex 32                                    → JWT_SECRET
#   openssl rand -hex 24                                    → POSTGRES_PASSWORD
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
#                                                           → ADMIN_PASSWORD_HASH
# ============================================================================

# --- Database ----------------------------------------------------------------
POSTGRES_USER=zaphelper
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=zaphelper

# --- Evolution API -----------------------------------------------------------
# Your existing Evolution API install. URL must be reachable from the zaphelper
# backend container (use a public URL or an internal docker network alias).
EVOLUTION_API_URL=https://evolution.yourdomain.com
EVOLUTION_API_KEY=your-evolution-api-key

# Unique name for this app's instance. If it doesn't exist yet, zaphelper
# creates it on first boot.
EVOLUTION_INSTANCE_NAME=zaphelper-main

# --- Webhook -----------------------------------------------------------------
# The public URL Evolution API will POST to when new messages arrive.
# Must terminate TLS (https). Served by the `web` nginx container.
WEBHOOK_URL=https://zaphelper.yourdomain.com/webhook

# --- Dashboard auth ----------------------------------------------------------
ADMIN_USER=admin
# Generate via: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_PASSWORD_HASH=$2a$12$replace-me-with-a-real-bcrypt-hash

# 32+ random characters. openssl rand -hex 32
JWT_SECRET=generate-a-long-random-secret-at-least-32-chars

# Set to "false" if you're running on plain http (e.g. localhost dev).
COOKIE_SECURE=true

# --- Lead parser -------------------------------------------------------------
# Any chat whose name contains this substring (case-insensitive) is treated
# as the leads group for /statustoday and /statusweek.
BE_HOME_LEADS_GROUP_NAME=Be Home Leads Scheduled

# --- Self identification -----------------------------------------------------
# OPTIONAL. If left blank, zaphelper auto-detects your WhatsApp number after
# you scan the QR code (via Evolution /instance/fetchInstances). Format:
# country code + number, digits only. Example: 15551234567 (US).
SELF_PHONE_NUMBER=

# --- Timezone ----------------------------------------------------------------
# Controls how /statustoday / /statusweek and /reminder interpret "today",
# "this week", and "HH:MM".
TZ=America/New_York

# --- Ports -------------------------------------------------------------------
# Port the web container listens on (host side). EasyPanel typically maps this
# to your public domain via its own reverse proxy.
WEB_PORT=8080
